# Copy to .env and fill in your values (never commit .env).
# Azure Cosmos DB for MongoDB API — connection string from Azure Portal.
AZURE_COSMOSDB_CONNECTION_STRING=mongodb://YOUR_ACCOUNT:YOUR_PRIMARY_KEY@YOUR_ACCOUNT.mongo.cosmos.azure.com:10255/?ssl=true&retrywrites=false&replicaSet=globaldb&maxIdleTimeMS=120000&appName=@YOUR_ACCOUNT@
